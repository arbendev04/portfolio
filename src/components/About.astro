---
const facts = [
  { label: "Ubicación", value: "Colombia · Proyectos en ES & LATAM" },
  { label: "Disponibilidad", value: "Nuevos proyectos en 2026" },
  { label: "Respuesta", value: "Menos de 24 horas" },
  { label: "Enfoque", value: "Resultados medibles, no solo código" },
];
---

<section class="about" id="sobre-mi">
  <div class="about__container">
    <div class="about__content">
      <div class="about__text">
        <span class="about__tagline">Sobre mí</span>
        <h2 class="about__title">El dev detrás<br/>del proyecto</h2>

        <p class="about__lead">
          Soy Santiago Arango, desarrollador web freelance con base en Colombia.
          Me especializo en construir sitios y tiendas en línea que no solo se ven bien —
          <strong>trabajan</strong>.
        </p>

        <p class="about__body">
          WordPress, Shopify, código a medida: elijo la herramienta correcta según lo
          que necesita tu negocio, no la más cómoda para mí. Trabajo con clientes en
          Colombia y España, desde e-commerce hasta aplicaciones web a medida.
        </p>

        <p class="about__body">
          Mi enfoque parte siempre del objetivo de negocio: más ventas, menos trabajo
          manual, mejor presencia digital. Cuando terminamos, tienes algo que realmente
          funciona.
        </p>

        <div class="about__cta-group">
          <a href="#contacto" class="about__cta">Hablemos →</a>
          <a
            href="https://github.com/ArbenS90"
            target="_blank"
            rel="noopener noreferrer"
            class="about__cta about__cta--ghost"
          >
            Ver GitHub
          </a>
        </div>
      </div>

      <div class="about__sidebar">
        <div class="about__card glass">
          <ul class="about__facts">
            {facts.map((fact) => (
              <li class="about__fact">
                <span class="about__fact-label">{fact.label}</span>
                <span class="about__fact-value">{fact.value}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="about__badge glass">
          <span class="about__badge-dot" aria-hidden="true"></span>
          <div class="about__badge-text">
            <span class="about__badge-status">Disponible</span>
            <span class="about__badge-detail">para nuevos proyectos</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 5rem 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .about__container {
    max-width: 1080px;
    margin: 0 auto;
  }

  .about__content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* ======= TEXT ======= */
  .about__tagline {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: 0.875rem;
  }

  .about__title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 400;
    letter-spacing: 0.08em;
    line-height: 1.0;
    margin-bottom: 1.75rem;
  }

  .about__lead {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.125rem);
    font-weight: 400;
    line-height: 1.75;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .about__lead strong {
    color: var(--color-primary);
    font-weight: 600;
  }

  .about__body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .about__body:last-of-type {
    margin-bottom: 2rem;
  }

  .about__cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }

  .about__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    min-height: 44px;
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 16px rgba(59, 130, 246, 0.3);
  }

  .about__cta:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.4);
  }

  .about__cta--ghost {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    box-shadow: none;
  }

  .about__cta--ghost:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
    background: rgba(255,255,255,0.03);
    transform: translateY(-2px);
  }

  /* ======= SIDEBAR ======= */
  .about__sidebar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about__card {
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .about__facts {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .about__fact {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .about__fact:first-child { padding-top: 0; }
  .about__fact:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .about__fact-label {
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-subtle);
  }

  .about__fact-value {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.4;
  }

  .about__badge {
    border-radius: var(--radius-lg);
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .about__badge-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    box-shadow: 0 0 10px #22c55e;
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(1.3); }
  }

  .about__badge-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .about__badge-status {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: #4ade80;
    letter-spacing: 0.02em;
  }

  .about__badge-detail {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-subtle);
  }

  /* ======= TABLET ======= */
  @media (min-width: 640px) {
    .about {
      padding: 5rem 2.5rem;
    }
  }

  /* ======= DESKTOP ======= */
  @media (min-width: 1024px) {
    .about {
      padding: 6rem 3rem;
    }

    .about__content {
      flex-direction: row;
      align-items: flex-start;
      gap: 5rem;
    }

    .about__text {
      flex: 1;
    }

    .about__sidebar {
      width: 320px;
      flex-shrink: 0;
      position: sticky;
      top: 4rem;
    }
  }
</style>
