---
type Logo = { name: string; src: string };

const stacks: Array<{ icon: string; title: string; logos: Logo[] }> = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>',
    title: "Desarrollo Web",
    logos: [
      { name: "WordPress",   src: "https://cdn.simpleicons.org/wordpress/21759B" },
      { name: "WooCommerce", src: "https://cdn.simpleicons.org/woocommerce/96588A" },
      { name: "Shopify",     src: "https://cdn.simpleicons.org/shopify/96BF48" },
      { name: "HTML / CSS",  src: "https://cdn.simpleicons.org/html5/E34F26" },
      { name: "Elementor",   src: "https://cdn.simpleicons.org/elementor/92003B" },
      { name: "Analytics",   src: "https://cdn.simpleicons.org/googleanalytics/E37400" },
    ],
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>',
    title: "Frameworks & Lenguajes",
    logos: [
      { name: "TypeScript", src: "https://cdn.simpleicons.org/typescript/3178C6" },
      { name: "PHP",        src: "https://cdn.simpleicons.org/php/777BB4" },
      { name: "React",      src: "https://cdn.simpleicons.org/react/61DAFB" },
      { name: "Angular",    src: "https://cdn.simpleicons.org/angular/DD0031" },
      { name: "Astro",      src: "https://cdn.simpleicons.org/astro/FF5D01" },
      { name: "PostgreSQL", src: "https://cdn.simpleicons.org/postgresql/4169E1" },
    ],
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>',
    title: "IA & Automatización",
    logos: [
      { name: "OpenAI",  src: "https://cdn.simpleicons.org/openai/10A37F" },
      { name: "Claude",  src: "https://cdn.simpleicons.org/anthropic/D4A27F" },
      { name: "N8N",     src: "https://cdn.simpleicons.org/n8n/EA4B71" },
      { name: "Python",  src: "https://cdn.simpleicons.org/python/3776AB" },
      { name: "Zapier",  src: "https://cdn.simpleicons.org/zapier/FF4A00" },
      { name: "Make",    src: "https://cdn.simpleicons.org/make/6D00CC" },
    ],
  },
];
---

<section class="tech-stack" id="habilidades">
  <div class="tech-stack__container">
    <div class="tech-stack__header">
      <span class="tech-stack__tagline">Lo que hago</span>
      <h2 class="tech-stack__title">Servicios</h2>
    </div>

    <div class="tech-stack__grid">
      {stacks.map((stack) => (
        <div class="stack-card glass">
          <div class="stack-card__header">
            <span class="stack-card__icon" set:html={stack.icon} aria-hidden="true" />
            <h3 class="stack-card__title">{stack.title}</h3>
          </div>

          <div class="stack-card__logos">
            {stack.logos.map((logo) => (
              <div class="stack-card__logo-item">
                <img
                  src={logo.src}
                  alt={logo.name}
                  width="18"
                  height="18"
                  loading="lazy"
                  class="stack-card__logo-img"
                />
                <span class="stack-card__logo-name">{logo.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech-stack {
    padding: 5rem 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .tech-stack__container {
    max-width: 1080px;
    margin: 0 auto;
  }

  .tech-stack__header {
    margin-bottom: 3.5rem;
  }

  .tech-stack__tagline {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: 0.875rem;
  }

  .tech-stack__title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 400;
    letter-spacing: 0.1em;
  }

  .tech-stack__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  /* ======= CARD ======= */
  .stack-card {
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    transition: all var(--transition-normal);
    cursor: default;
  }

  .stack-card:hover {
    border-color: rgba(59, 130, 246, 0.22);
    transform: translateY(-4px);
    box-shadow: 0 14px 36px -10px rgba(59, 130, 246, 0.18);
  }

  .stack-card__header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .stack-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .stack-card__title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1.2;
  }

  /* ======= LOGO GRID ======= */
  .stack-card__logos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem 1rem;
  }

  .stack-card__logo-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    transition: all var(--transition-fast);
  }

  .stack-card__logo-item:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: var(--color-border-hover);
  }

  .stack-card__logo-img {
    width: 18px;
    height: 18px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .stack-card__logo-name {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* ======= TABLET (640px – 1023px) ======= */
  @media (min-width: 640px) {
    .tech-stack {
      padding: 5rem 2.5rem;
    }

    .tech-stack__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  /* ======= DESKTOP (≥1024px) ======= */
  @media (min-width: 1024px) {
    .tech-stack {
      padding: 6rem 3rem;
    }

    .stack-card {
      padding: 2.25rem 2rem;
    }
  }
</style>
