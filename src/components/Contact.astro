---
---

<section class="contact" id="contacto">
  <div class="contact__glow" aria-hidden="true"></div>
  <div class="contact__container">
    <div class="contact__heading">
      <span class="contact__tagline">Hablemos sin compromiso</span>
      <h2 class="contact__title">
        ¿Tu negocio necesita<br />
        <span class="text-gradient">crecer en línea?</span>
      </h2>
    </div>

    <p class="contact__description">
      Disponible para nuevos proyectos en 2026. Cuéntame qué necesitas
      y te respondo en menos de 24 horas — sin rodeos, sin burocracia.
    </p>

    <form class="contact__form" novalidate>
      <div class="contact__form-row">
        <div class="contact__field">
          <label for="contact-name" class="contact__label">Tu nombre</label>
          <input
            id="contact-name"
            type="text"
            class="contact__input"
            placeholder="Santiago García"
            required
            autocomplete="name"
          />
        </div>
        <div class="contact__field">
          <label for="contact-email" class="contact__label">Tu correo</label>
          <input
            id="contact-email"
            type="email"
            class="contact__input"
            placeholder="correo@ejemplo.com"
            required
            autocomplete="email"
          />
        </div>
      </div>

      <div class="contact__field">
        <label for="contact-phone" class="contact__label">WhatsApp <span class="contact__optional">(opcional)</span></label>
        <input
          id="contact-phone"
          type="tel"
          class="contact__input"
          placeholder="+57 300 000 0000"
          autocomplete="tel"
        />
      </div>

      <div class="contact__field">
        <label for="contact-message" class="contact__label">Tu proyecto</label>
        <textarea
          id="contact-message"
          class="contact__input contact__textarea"
          placeholder="Cuéntame qué necesitas, qué tipo de proyecto es, y cualquier detalle relevante…"
          rows="4"
          required
        ></textarea>
      </div>

      <button type="submit" class="contact__button">
        Enviar y empezar
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </button>
    </form>
  </div>
</section>

<style>
  .contact {
    position: relative;
    padding: 5rem 1.25rem 6rem;
    border-top: 1px solid var(--color-border);
    overflow: hidden;
  }

  .contact__glow {
    position: absolute;
    top: -10%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.08) 0%, transparent 65%);
    filter: blur(50px);
    pointer-events: none;
  }

  .contact__container {
    position: relative;
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Encabezado */
  .contact__heading { display: flex; flex-direction: column; gap: 0.625rem; }

  .contact__tagline {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
  }

  .contact__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5.5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: 0.1em;
    line-height: 1.06;
  }

  .contact__description {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text-muted);
    max-width: 46ch;
  }

  /* Formulario */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact__label {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }

  .contact__optional {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--color-text-subtle);
    font-family: var(--font-body);
  }

  .contact__input {
    background: rgba(255,255,255,0.025);
    border: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--radius-md);
    padding: 0.875rem 1.125rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 400;
    color: var(--color-text);
    transition: all var(--transition-fast);
    width: 100%;
    min-height: 44px;
  }

  .contact__input::placeholder {
    color: var(--color-text-subtle);
    font-weight: 300;
  }

  .contact__input:hover {
    background: rgba(255,255,255,0.04);
    border-color: var(--color-border-hover);
  }

  .contact__input:focus {
    outline: none;
    border-color: rgba(59, 130, 246, 0.5);
    background: rgba(59, 130, 246, 0.04);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.12);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 130px;
    line-height: 1.65;
  }

  .contact__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--color-primary);
    color: white;
    padding: 0.9375rem 2.25rem;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all var(--transition-fast);
    box-shadow: 0 4px 16px rgba(59, 130, 246, 0.35);
    cursor: pointer;
    min-height: 48px;
    align-self: stretch; /* ancho completo en móvil */
  }

  .contact__button:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.45);
  }

  .contact__button svg {
    transition: transform var(--transition-fast);
  }

  .contact__button:hover svg {
    transform: translateX(3px);
  }

  /* ======= TABLET (640px – 1023px) ======= */
  @media (min-width: 640px) {
    .contact {
      padding: 6rem 2.5rem 7rem;
    }

    .contact__form-row {
      grid-template-columns: repeat(2, 1fr);
    }

    .contact__button {
      align-self: flex-start; /* botón compacto en desktop */
    }
  }

  /* ======= DESKTOP (≥1024px) ======= */
  @media (min-width: 1024px) {
    .contact {
      padding: 8rem 3rem 9rem;
    }
  }
</style>
