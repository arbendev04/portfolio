---
const projects = [
  {
    title: "Tienda Online",
    tag: "E-Commerce",
    description:
      "Tienda WooCommerce con catálogo, carrito y pasarela de pagos integrada. El cliente pasó de cero ventas digitales a +40% de ingresos en el primer mes.",
    techs: ["WordPress", "WooCommerce", "PHP"],
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuDLLb7Xs4NM3GJKtlkkJbGdJgGYdXa6LASgyT5RHK-Ri7DD_I3rNmJGQsRTWpatpgDwloWCAzEPwmQUNZhOhiVZY6VRk7TejdYsV6CmO7aOCBQxuo0niDxjBOnCJdZKodWbeQQjAjvyisro_xKonmd7LW9W-6J2C9xBArmGjTBse6M9T93Lu79li7INteQ5f6xrjH-wxAerm8Wf_v6IvJ34gD-O400VzzoMyRctXjUJfTT7IYCSqaSSUwgANvdrwHp2FhvfgZtWRC8",
  },
  {
    title: "Sistema Web",
    tag: "App a Medida",
    description:
      "Aplicación Django con panel de administración, gestión de usuarios y reportes automáticos. Resultado: 10 horas semanales de trabajo manual eliminadas.",
    techs: ["Python", "Django", "PostgreSQL"],
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuBFnUQu7n6Wjzi4oyvOS5rGk-WF-vinFg3NjI3_CPB-fD3gdSyiT2hdbn2GuYL1jurMCZQiyVTM_9t0fnqnZykP6tFeKxp5b5g6IN-ZT2hVG8XG7z6NO60Vb0OfrPETD85sG__R8KpcwOM1JTUABRDskw73XdGx9ifv4K5R0t9aX3pIesHDz29zNO9Pl5Be1ujg9SYY-DzFalo8Ce1XuZ5jPk5IVvE4xqCkst-VzZxU5HUXv7HxIeUD2zJIYGJQiqc6CflIZhca8O0",
  },
];
---

<section class="projects" id="proyectos">
  <div class="projects__container">
    <div class="projects__header">
      <div>
        <span class="projects__tagline">Proyectos Seleccionados</span>
        <h2 class="projects__title">Resultados Reales</h2>
      </div>
      <a href="#contacto" class="projects__link">¿El siguiente es el tuyo?</a>
    </div>

    <div class="projects__grid">
      {projects.map((project) => (
        <article class="project-card glass">
          <div class="project-card__image-container">
            <div
              class="project-card__image"
              style={`background-image: url('${project.image}')`}
              role="img"
              aria-label={`Imagen del proyecto: ${project.title}`}
            />
          </div>
          <div class="project-card__content">
            <div class="project-card__header">
              <h3 class="project-card__title">{project.title}</h3>
              <span class="project-card__tag">{project.tag}</span>
            </div>
            <p class="project-card__description">{project.description}</p>
            <div class="project-card__techs">
              {project.techs.map((tech) => (
                <span class="project-card__tech">{tech}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 5rem 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  .projects__container {
    max-width: 1080px;
    margin: 0 auto;
  }

  .projects__header {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .projects__tagline {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: 0.875rem;
  }

  .projects__title {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 800;
    letter-spacing: 0.1em;
  }

  .projects__link {
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-primary);
    border-bottom: 1px solid rgba(59, 130, 246, 0.35);
    padding-bottom: 0.2rem;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .projects__link:hover {
    border-color: var(--color-primary);
    color: #93c5fd;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .project-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-normal);
    cursor: pointer;
  }

  .project-card:hover,
  .project-card:focus-within {
    border-color: rgba(59, 130, 246, 0.25);
    transform: translateY(-5px);
    box-shadow: 0 16px 40px -12px rgba(59, 130, 246, 0.2);
  }

  .project-card__image-container {
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .project-card__image {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.9s cubic-bezier(0.2, 1, 0.2, 1);
  }

  .project-card:hover .project-card__image {
    transform: scale(1.08) rotate(0.5deg);
  }

  .project-card__content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .project-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .project-card__title {
    font-family: var(--font-heading);
    font-size: 1.1875rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .project-card__tag {
    flex-shrink: 0;
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 700;
    padding: 0.25rem 0.625rem;
    border: 1px solid rgba(59, 130, 246, 0.2);
    color: var(--color-primary);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .project-card__description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .project-card__techs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem 0.75rem;
    padding-top: 0.25rem;
    border-top: 1px solid var(--color-border);
  }

  .project-card__tech {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-subtle);
  }

  /* ======= TABLET (640px – 1023px) ======= */
  @media (min-width: 640px) {
    .projects {
      padding: 5rem 2.5rem;
    }

    .projects__header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .projects__link { align-self: auto; }

    .projects__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ======= DESKTOP (≥1024px) ======= */
  @media (min-width: 1024px) {
    .projects {
      padding: 6rem 3rem;
    }

    .project-card__content { padding: 1.75rem 2rem; }
  }
</style>
