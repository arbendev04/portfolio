---
import { projects } from "../data/projects";

const stats = [
  { value: `${projects.length}+`, label: "Proyectos lanzados" },
  { value: "4+",                  label: "Años de experiencia" },
  { value: `${projects.length}+`, label: "Clientes atendidos" },
];
---

<section class="hero" id="inicio">
  <div class="hero__content">
    <header class="hero__header animate-in">
      <div class="hero__logo" aria-hidden="true">
        <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path clip-rule="evenodd" d="M12.0799 24L4 19.2479L9.95537 8.75216L18.04 13.4961L18.0446 4H29.9554L29.96 13.4961L38.0446 8.75216L44 19.2479L35.92 24L44 28.7521L38.0446 39.2479L29.96 34.5039L29.9554 44H18.0446L18.04 34.5039L9.95537 39.2479L4 28.7521L12.0799 24Z" fill="currentColor" fill-rule="evenodd"/>
        </svg>
      </div>
      <span class="hero__brand">Santiago Arango · Dev</span>
    </header>

    <div class="hero__main">
      <span class="hero__tagline animate-in animate-in--delay-1">WordPress · Shopify · Código a Medida</span>
      <h1 class="hero__title animate-in animate-in--delay-2">
        Tu web que <em class="hero__title-em">vende</em>
        <span class="hero__title-sub">hecha para ganar.</span>
      </h1>
      <p class="hero__description animate-in animate-in--delay-3">
        Diseño y construyo webs que convierten visitas en clientes reales —
        sin plantillas genéricas. WordPress, Shopify o código a medida
        según lo que tu negocio realmente necesite.
      </p>
      <div class="hero__buttons animate-in animate-in--delay-4">
        <a href="#proyectos" class="btn btn--primary">Ver proyectos</a>
        <a href="#contacto" class="btn btn--outline">Pedir presupuesto →</a>
      </div>
    </div>

    <div class="hero__stats animate-in animate-in--delay-5">
      {stats.map((stat) => (
        <div class="stat">
          <span class="stat__value">{stat.value}</span>
          <span class="stat__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Panel visual -->
  <div class="hero__visual" aria-hidden="true">

    <!-- MAPA MUNDO -->
    <div class="panel-card panel-map glass">
      <div class="panel-card__head">
        <span class="panel-eyebrow">Alcance global</span>
      </div>

      <!--
        Proyección equirectangular: viewBox 460×220
        x = (lon + 180) / 360 * 460
        y = (90  - lat) / 180 * 220
        Miami    lon=-80 lat=26  → x=128 y=78
        Medellín lon=-76 lat=6   → x=133 y=103
        Madrid   lon=-4  lat=40  → x=225 y=61
      -->
      <svg class="map__svg" viewBox="0 0 460 220" fill="none" xmlns="http://www.w3.org/2000/svg">

        <!-- Continentes (muy sutiles) -->
        <!-- Norteamérica -->
        <path class="map__land"
          d="M 19 35 L 55 33 L 68 48 L 82 70 L 100 86 L 115 91
             L 128 78 L 136 60 L 162 52 L 159 44 L 128 33
             L 140 20 L 100 18 L 75 20 Z"/>
        <!-- Groenlandia -->
        <path class="map__land"
          d="M 148 16 L 172 14 L 200 22 L 198 32 L 172 36 L 148 28 Z"/>
        <!-- Sudamérica -->
        <path class="map__land"
          d="M 128 83 L 158 97 L 197 103 L 192 122 L 165 138
             L 142 161 L 132 160 L 138 108 L 126 101 Z"/>
        <!-- Europa -->
        <path class="map__land"
          d="M 179 65 L 186 38 L 222 22 L 248 24 L 262 30
             L 248 60 L 232 65 L 224 66 L 214 65 L 182 66 Z"/>
        <!-- África -->
        <path class="map__land"
          d="M 182 66 L 214 65 L 248 72 L 268 94 L 252 112
             L 240 138 L 222 138 L 212 132 L 210 108
             L 198 102 L 170 90 L 174 74 Z"/>
        <!-- Asia (continente, simplificado) -->
        <path class="map__land"
          d="M 248 60 L 262 30 L 282 26 L 402 30 L 428 46
             L 406 64 L 378 60 L 352 74 L 320 86 L 302 100
             L 265 94 L 255 72 L 232 65 Z"/>
        <!-- India -->
        <path class="map__land"
          d="M 302 100 L 318 90 L 330 100 L 320 116 L 308 114 Z"/>
        <!-- Indochina -->
        <path class="map__land"
          d="M 352 74 L 368 80 L 372 96 L 358 100 L 346 92 Z"/>
        <!-- Japón -->
        <path class="map__land"
          d="M 406 58 L 414 52 L 420 58 L 414 66 L 406 64 Z"/>
        <!-- Australia -->
        <path class="map__land"
          d="M 368 134 L 392 110 L 412 110 L 420 130 L 416 144
             L 404 148 L 382 144 Z"/>
        <!-- Nueva Zelanda (pequeña) -->
        <path class="map__land"
          d="M 432 148 L 436 140 L 440 148 L 436 155 Z"/>
        <!-- Reino Unido / Irlanda (pequeño) -->
        <path class="map__land"
          d="M 175 36 L 180 32 L 183 38 L 178 44 Z"/>
        <!-- Islandia -->
        <path class="map__land"
          d="M 155 22 L 165 20 L 168 26 L 158 28 Z"/>

        <!-- Arcos de conexión -->
        <path class="map__arc map__arc--1"
          d="M 128 78 Q 178 20 225 61"
          stroke="rgba(59,130,246,0.6)" stroke-width="1.5"
          stroke-dasharray="7 5" stroke-linecap="round"/>
        <path class="map__arc map__arc--2"
          d="M 133 103 Q 180 14 225 61"
          stroke="rgba(34,211,238,0.45)" stroke-width="1.3"
          stroke-dasharray="7 5" stroke-linecap="round"/>
        <path class="map__arc map__arc--3"
          d="M 128 78 Q 130 90 133 103"
          stroke="rgba(251,191,36,0.5)" stroke-width="1.2"
          stroke-dasharray="4 4" stroke-linecap="round"/>

        <!-- Miami -->
        <circle class="map__ring" cx="128" cy="78" r="16" fill="rgba(34,211,238,0.07)"/>
        <circle cx="128" cy="78" r="6" fill="rgba(34,211,238,0.2)" stroke="rgba(34,211,238,0.75)" stroke-width="1.5"/>
        <circle cx="128" cy="78" r="2.5" fill="#22d3ee"/>
        <text x="140" y="74" class="map__city">Miami</text>
        <text x="140" y="84" class="map__country">Florida · USA</text>

        <!-- Medellín -->
        <circle class="map__ring map__ring--yellow" cx="133" cy="103" r="16" fill="rgba(251,191,36,0.07)"/>
        <circle cx="133" cy="103" r="6" fill="rgba(251,191,36,0.2)" stroke="rgba(251,191,36,0.75)" stroke-width="1.5"/>
        <circle cx="133" cy="103" r="2.5" fill="#fbbf24"/>
        <text x="145" y="100" class="map__city">Medellín</text>
        <text x="145" y="110" class="map__country">Colombia</text>

        <!-- Madrid -->
        <circle class="map__ring map__ring--blue" cx="225" cy="61" r="16" fill="rgba(59,130,246,0.07)"/>
        <circle cx="225" cy="61" r="6" fill="rgba(59,130,246,0.2)" stroke="rgba(59,130,246,0.75)" stroke-width="1.5"/>
        <circle cx="225" cy="61" r="2.5" fill="#3b82f6"/>
        <text x="225" y="42" class="map__city" text-anchor="middle">España</text>
        <text x="225" y="51" class="map__country" text-anchor="middle">Madrid</text>
      </svg>
    </div>

    <!-- TERMINAL -->
    <div class="panel-card panel-terminal glass">
      <div class="terminal__bar">
        <span class="terminal__dot terminal__dot--red"></span>
        <span class="terminal__dot terminal__dot--yellow"></span>
        <span class="terminal__dot terminal__dot--green"></span>
        <span class="terminal__title">bash — santiago@dev</span>
      </div>
      <div class="terminal__body">
        <p class="terminal__line t-l1">
          <span class="t-prompt">~/proyecto</span><span class="t-cmd"> $ npm run build</span>
        </p>
        <p class="terminal__line t-l2">
          <span class="t-ok">✓</span><span class="t-out"> Build completado en <span class="t-hi">0.8s</span></span>
        </p>
        <p class="terminal__line t-l3">
          <span class="t-ok">✓</span><span class="t-out"> Performance  <span class="t-score">98</span>/100</span>
        </p>
        <p class="terminal__line t-l4">
          <span class="t-ok">✓</span><span class="t-out"> SEO          <span class="t-score">100</span>/100</span>
        </p>
        <p class="terminal__line t-l5">
          <span class="t-prompt">~/proyecto</span><span class="t-cmd"> $ git push origin main</span>
        </p>
        <p class="terminal__line t-l6">
          <span class="t-ok">↑</span><span class="t-out"> Desplegado en producción · <span class="t-hi">netlify.app</span></span>
        </p>
        <p class="terminal__line t-l7">
          <span class="t-prompt">~/proyecto</span><span class="t-cmd"> $ <span class="t-cursor">▌</span></span>
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  /* ======= BASE ======= */
  .hero {
    display: flex;
    min-height: 100svh;
    background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 36px 36px;
  }

  /* ======= CONTENT ======= */
  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    padding: 1.75rem 1.25rem 2rem;
    gap: 3rem;
  }

  .hero__header { display: flex; align-items: center; gap: 0.875rem; }

  .hero__logo {
    width: 1.75rem; height: 1.75rem;
    color: var(--color-primary);
    transition: transform var(--transition-slow);
    flex-shrink: 0;
  }
  .hero__header:hover .hero__logo { transform: rotate(90deg); }

  .hero__brand {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
  }

  .hero__main { display: flex; flex-direction: column; gap: 1.5rem; }

  .hero__tagline {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-primary);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9.5vw, 6.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
  }

  .hero__title-em { font-style: normal; color: var(--color-primary); }

  .hero__title-sub {
    display: block;
    font-family: var(--font-display);
    font-size: 0.22em;
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-top: 1.2em;
    padding-left: 0.75em;
    border-left: 2px solid rgba(59,130,246,0.5);
  }

  .hero__description {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.125rem);
    font-weight: 400;
    line-height: 1.75;
    color: var(--color-text-muted);
    max-width: 44ch;
  }

  .hero__buttons { display: flex; flex-wrap: wrap; gap: 0.875rem; }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    min-height: 44px;
  }
  .btn--primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 16px rgba(59,130,246,0.35);
  }
  .btn--primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(59,130,246,0.45);
  }
  .btn--outline {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .btn--outline:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
    transform: translateY(-2px);
    background: rgba(255,255,255,0.03);
  }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
  }
  .stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .stat__value {
    font-family: var(--font-body);
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }
  .stat__label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
  }

  /* ======= VISUAL — oculto en móvil ======= */
  .hero__visual { display: none; }

  /* ======= TABLET ======= */
  @media (min-width: 640px) and (max-width: 1023px) {
    .hero { flex-direction: column; }
    .hero__content { padding: 5.5rem 3rem 3.5rem; gap: 2.5rem; }
    .hero__main { max-width: 560px; }
    .hero__description { max-width: 52ch; }
  }

  /* ======= DESKTOP ======= */
  @media (min-width: 1024px) {
    .hero { flex-direction: row; }

    .hero__content {
      width: 50%;
      padding: 5rem 4.5rem;
      gap: 0;
      justify-content: space-between;
    }
    .hero__main { max-width: 520px; }

    /* Panel derecho */
    .hero__visual {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      width: 50%;
      padding: 3rem 2.5rem;
      background-color: #05091a;
      border-left: 1px solid rgba(255,255,255,0.08);
      position: relative;
      overflow: hidden;
    }

    .hero__visual::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 55% at 65% 25%, rgba(59,130,246,0.1) 0%, transparent 70%),
        radial-gradient(ellipse 50% 45% at 25% 80%, rgba(34,211,238,0.07) 0%, transparent 60%);
      pointer-events: none;
    }

    /* ── Cards base ── */
    .panel-card {
      border-radius: var(--radius-lg);
      position: relative;
      z-index: 1;
      transition: border-color var(--transition-normal), transform var(--transition-normal);
    }
    .panel-card:hover {
      border-color: rgba(59,130,246,0.25);
      transform: translateY(-2px);
    }

    /* ── Mapa ── */
    .panel-map {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
      padding: 1.5rem 1.75rem;
      min-height: 0;
      overflow: hidden;
    }

    .panel-card__head {
      display: flex;
      align-items: center;
    }

    .panel-eyebrow {
      font-family: var(--font-body);
      font-size: 0.625rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--color-text-subtle);
    }

    .map__svg {
      width: 100%;
      height: auto;
      flex: 1;
      min-height: 0;
    }

    /* Continentes */
    .map__land {
      fill: rgba(255,255,255,0.04);
      stroke: rgba(255,255,255,0.09);
      stroke-width: 0.5;
      stroke-linejoin: round;
    }

    /* Arcos */
    .map__arc {
      fill: none;
      stroke-dashoffset: 600;
      animation: drawArc 2s cubic-bezier(0.4,0,0.2,1) forwards;
    }
    .map__arc--1 { animation-delay: 0.3s; }
    .map__arc--2 { animation-delay: 0.6s; }
    .map__arc--3 { animation-delay: 0.1s; }

    /* Pulso de puntos */
    .map__ring {
      animation: mapPulse 2.8s ease-in-out infinite;
    }
    .map__ring--yellow { animation-delay: 0.5s; }
    .map__ring--blue   { animation-delay: 1s; }

    .map__city {
      font-family: var(--font-body);
      font-size: 11px;
      font-weight: 700;
      fill: var(--color-text);
      letter-spacing: 0.01em;
    }
    .map__country {
      font-family: var(--font-body);
      font-size: 9px;
      font-weight: 400;
      fill: var(--color-text-subtle);
      letter-spacing: 0.04em;
    }

    /* ── Terminal (más pequeña) ── */
    .panel-terminal {
      flex: 0 0 190px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      padding: 0;
      background: rgba(2,6,23,0.85);
    }

    .terminal__bar {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.625rem 1rem;
      background: rgba(255,255,255,0.03);
      border-bottom: 1px solid var(--color-border);
      flex-shrink: 0;
    }
    .terminal__dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .terminal__dot--red    { background: #ff5f57; }
    .terminal__dot--yellow { background: #febc2e; }
    .terminal__dot--green  { background: #28c840; }
    .terminal__title {
      font-family: var(--font-body);
      font-size: 0.5625rem;
      font-weight: 500;
      color: var(--color-text-subtle);
      letter-spacing: 0.06em;
      margin: 0 auto;
    }

    .terminal__body {
      padding: 0.875rem 1.125rem;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      flex: 1;
      overflow: hidden;
    }

    .terminal__line {
      font-family: 'Courier New', 'Fira Code', monospace;
      font-size: 0.75rem;
      line-height: 1.6;
      opacity: 0;
      transform: translateY(3px);
      animation: fadeInLine 0.2s ease forwards;
      white-space: pre;
    }
    .t-l1 { animation-delay: 0.5s; }
    .t-l2 { animation-delay: 1.1s; }
    .t-l3 { animation-delay: 1.5s; }
    .t-l4 { animation-delay: 1.85s; }
    .t-l5 { animation-delay: 2.4s; }
    .t-l6 { animation-delay: 3.0s; }
    .t-l7 { animation-delay: 3.6s; }

    .t-prompt { color: #818cf8; }
    .t-cmd    { color: var(--color-text-muted); }
    .t-ok     { color: #22c55e; }
    .t-out    { color: #64748b; }
    .t-score  { color: #22d3ee; font-weight: 700; }
    .t-hi     { color: #a5f3fc; }

    .t-cursor {
      color: #22d3ee;
      opacity: 0;
      animation: blink 1s step-end infinite;
      animation-delay: 4s;
    }
  }

  /* ======= KEYFRAMES ======= */
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(1.35); }
  }
  @keyframes mapPulse {
    0%, 100% { opacity: 0.55; }
    50%       { opacity: 0.12; }
  }
  @keyframes drawArc {
    to { stroke-dashoffset: 0; }
  }
  @keyframes fadeInLine {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>
