---
import { projects } from "../data/projects";

const stats = [
  { value: `${projects.length}+`, label: "Proyectos lanzados" },
  { value: "4+",                  label: "Años de experiencia" },
  { value: `${projects.length}+`, label: "Clientes atendidos" },
];
---

<section class="hero" id="inicio">
  <div class="hero__content">
    <header class="hero__header animate-in">
      <div class="hero__logo" aria-hidden="true">
        <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path clip-rule="evenodd" d="M12.0799 24L4 19.2479L9.95537 8.75216L18.04 13.4961L18.0446 4H29.9554L29.96 13.4961L38.0446 8.75216L44 19.2479L35.92 24L44 28.7521L38.0446 39.2479L29.96 34.5039L29.9554 44H18.0446L18.04 34.5039L9.95537 39.2479L4 28.7521L12.0799 24Z" fill="currentColor" fill-rule="evenodd"/>
        </svg>
      </div>
      <span class="hero__brand">Santiago Arango · Dev</span>
    </header>

    <div class="hero__main">
      <span class="hero__tagline animate-in animate-in--delay-1">WordPress · Shopify · Código a Medida</span>
      <h1 class="hero__title animate-in animate-in--delay-2">
        Tu web que <em class="hero__title-em">vende</em>
        <span class="hero__title-sub">hecha para ganar.</span>
      </h1>
      <p class="hero__description animate-in animate-in--delay-3">
        Diseño y construyo webs que convierten visitas en clientes reales —
        sin plantillas genéricas. WordPress, Shopify o código a medida
        según lo que tu negocio realmente necesite.
      </p>
      <div class="hero__buttons animate-in animate-in--delay-4">
        <a href="#proyectos" class="btn btn--primary">Ver proyectos</a>
        <a href="#contacto" class="btn btn--outline">Pedir presupuesto →</a>
      </div>
    </div>

    <div class="hero__stats animate-in animate-in--delay-5">
      {stats.map((stat) => (
        <div class="stat">
          <span class="stat__value">{stat.value}</span>
          <span class="stat__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Panel visual -->
  <div class="hero__visual" aria-hidden="true">

    <!-- MAPA MUNDO -->
    <div class="panel-card panel-map glass">
      <div class="panel-card__head">
        <span class="panel-eyebrow">Alcance global</span>
      </div>

      <!--
        Globo — proyección ortográfica centrada en el Atlántico (lon=-40, lat=15)
        Centro SVG: cx=230 cy=122  R=105
        Miami    → (168, 99)
        Medellín → (172, 126)
        Madrid   → (284, 73)
      -->
      <svg class="map__svg" viewBox="0 0 460 244" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Gradiente 3D para la esfera -->
          <radialGradient id="globeFill" cx="38%" cy="32%" r="68%" gradientUnits="objectBoundingBox">
            <stop offset="0%"   stop-color="rgba(59,130,246,0.22)"/>
            <stop offset="45%"  stop-color="rgba(15,25,60,0.35)"/>
            <stop offset="100%" stop-color="rgba(2,6,23,0.75)"/>
          </radialGradient>
          <!-- Brillo atmosférico en el borde -->
          <radialGradient id="globeAtmo" cx="50%" cy="50%" r="50%">
            <stop offset="82%"  stop-color="transparent"/>
            <stop offset="100%" stop-color="rgba(59,130,246,0.18)"/>
          </radialGradient>
          <!-- Clip al círculo del globo -->
          <clipPath id="gc">
            <circle cx="230" cy="122" r="105"/>
          </clipPath>
        </defs>

        <!-- Atmósfera exterior -->
        <circle cx="230" cy="122" r="113" fill="url(#globeAtmo)"/>

        <!-- Esfera base -->
        <circle cx="230" cy="122" r="105"
          fill="url(#globeFill)"
          stroke="rgba(255,255,255,0.12)" stroke-width="0.8"/>

        <!-- Graticule (meridianos y paralelos) — clipped -->
        <g clip-path="url(#gc)">
          <!-- Paralelos de latitud -->
          <ellipse cx="230" cy="122" rx="105" ry="21" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="0.6"/>
          <ellipse cx="230" cy="99"  rx="102" ry="20" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"/>
          <ellipse cx="230" cy="77"  rx="91"  ry="18" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"/>
          <ellipse cx="230" cy="56"  rx="74"  ry="15" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="0.5"/>
          <ellipse cx="230" cy="37"  rx="49"  ry="10" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="0.5"/>
          <ellipse cx="230" cy="145" rx="102" ry="20" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"/>
          <ellipse cx="230" cy="167" rx="91"  ry="18" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="0.5"/>
          <ellipse cx="230" cy="188" rx="74"  ry="15" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="0.5"/>
          <ellipse cx="230" cy="207" rx="49"  ry="10" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="0.5"/>

          <!-- Meridianos de longitud -->
          <line x1="230" y1="17" x2="230" y2="227" stroke="rgba(255,255,255,0.08)" stroke-width="0.6"/>
          <ellipse cx="230" cy="122" rx="53"  ry="105" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"/>
          <ellipse cx="230" cy="122" rx="91"  ry="105" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="0.5"/>

          <!-- Arcos de vuelo — dentro del globo -->
          <path class="map__arc map__arc--1"
            d="M 168 99 Q 222 50 284 73"
            stroke="rgba(59,130,246,0.7)" stroke-width="1.6"
            stroke-dasharray="7 5" stroke-linecap="round"/>
          <path class="map__arc map__arc--2"
            d="M 172 126 Q 224 38 284 73"
            stroke="rgba(34,211,238,0.55)" stroke-width="1.4"
            stroke-dasharray="7 5" stroke-linecap="round"/>
          <path class="map__arc map__arc--3"
            d="M 168 99 Q 170 112 172 126"
            stroke="rgba(251,191,36,0.55)" stroke-width="1.3"
            stroke-dasharray="4 4" stroke-linecap="round"/>
        </g>

        <!-- Borde del globo (encima del clip) -->
        <circle cx="230" cy="122" r="105"
          fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="0.8"/>

        <!-- Miami -->
        <circle class="map__ring" cx="168" cy="99" r="18" fill="rgba(34,211,238,0.08)"/>
        <circle cx="168" cy="99" r="6.5" fill="rgba(34,211,238,0.25)" stroke="rgba(34,211,238,0.85)" stroke-width="1.5"/>
        <circle cx="168" cy="99" r="2.5" fill="#22d3ee"/>
        <text x="181" y="95"  class="map__city">Miami</text>
        <text x="181" y="106" class="map__country">Florida · USA</text>

        <!-- Medellín -->
        <circle class="map__ring map__ring--yellow" cx="172" cy="126" r="18" fill="rgba(251,191,36,0.08)"/>
        <circle cx="172" cy="126" r="6.5" fill="rgba(251,191,36,0.25)" stroke="rgba(251,191,36,0.85)" stroke-width="1.5"/>
        <circle cx="172" cy="126" r="2.5" fill="#fbbf24"/>
        <text x="185" y="122" class="map__city">Medellín</text>
        <text x="185" y="133" class="map__country">Colombia</text>

        <!-- Madrid -->
        <circle class="map__ring map__ring--blue" cx="284" cy="73" r="18" fill="rgba(59,130,246,0.08)"/>
        <circle cx="284" cy="73" r="6.5" fill="rgba(59,130,246,0.25)" stroke="rgba(59,130,246,0.85)" stroke-width="1.5"/>
        <circle cx="284" cy="73" r="2.5" fill="#3b82f6"/>
        <text x="297" y="69"  class="map__city">España</text>
        <text x="297" y="80"  class="map__country">Madrid</text>
      </svg>
    </div>

    <!-- TERMINAL -->
    <div class="panel-card panel-terminal glass">
      <div class="terminal__bar">
        <span class="terminal__dot terminal__dot--red"></span>
        <span class="terminal__dot terminal__dot--yellow"></span>
        <span class="terminal__dot terminal__dot--green"></span>
        <span class="terminal__title">bash — santiago@dev</span>
      </div>
      <div class="terminal__body">
        <p class="terminal__line t-l1">
          <span class="t-prompt">~/proyecto</span><span class="t-cmd"> $ npm run build</span>
        </p>
        <p class="terminal__line t-l2">
          <span class="t-ok">✓</span><span class="t-out"> Build completado en <span class="t-hi">0.8s</span></span>
        </p>
        <p class="terminal__line t-l3">
          <span class="t-ok">✓</span><span class="t-out"> Performance  <span class="t-score">98</span>/100</span>
        </p>
        <p class="terminal__line t-l4">
          <span class="t-ok">✓</span><span class="t-out"> SEO          <span class="t-score">100</span>/100</span>
        </p>
        <p class="terminal__line t-l5">
          <span class="t-prompt">~/proyecto</span><span class="t-cmd"> $ git push origin main</span>
        </p>
        <p class="terminal__line t-l6">
          <span class="t-ok">↑</span><span class="t-out"> Desplegado en producción · <span class="t-hi">netlify.app</span></span>
        </p>
        <p class="terminal__line t-l7">
          <span class="t-prompt">~/proyecto</span><span class="t-cmd"> $ <span class="t-cursor">▌</span></span>
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  /* ======= BASE ======= */
  .hero {
    display: flex;
    min-height: 100svh;
    background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 36px 36px;
  }

  /* ======= CONTENT ======= */
  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    padding: 1.75rem 1.25rem 2rem;
    gap: 3rem;
  }

  .hero__header { display: flex; align-items: center; gap: 0.875rem; }

  .hero__logo {
    width: 1.75rem; height: 1.75rem;
    color: var(--color-primary);
    transition: transform var(--transition-slow);
    flex-shrink: 0;
  }
  .hero__header:hover .hero__logo { transform: rotate(90deg); }

  .hero__brand {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
  }

  .hero__main { display: flex; flex-direction: column; gap: 1.5rem; }

  .hero__tagline {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-primary);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9.5vw, 6.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
  }

  .hero__title-em { font-style: normal; color: var(--color-primary); }

  .hero__title-sub {
    display: block;
    font-family: var(--font-display);
    font-size: 0.22em;
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-top: 1.2em;
    padding-left: 0.75em;
    border-left: 2px solid rgba(59,130,246,0.5);
  }

  .hero__description {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.125rem);
    font-weight: 400;
    line-height: 1.75;
    color: var(--color-text-muted);
    max-width: 44ch;
  }

  .hero__buttons { display: flex; flex-wrap: wrap; gap: 0.875rem; }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    min-height: 44px;
  }
  .btn--primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 16px rgba(59,130,246,0.35);
  }
  .btn--primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(59,130,246,0.45);
  }
  .btn--outline {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .btn--outline:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
    transform: translateY(-2px);
    background: rgba(255,255,255,0.03);
  }

  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
  }
  .stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .stat__value {
    font-family: var(--font-body);
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }
  .stat__label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
  }

  /* ======= PANEL VISUAL — oculto en móvil ======= */
  .hero__visual {
    display: none;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem 1.25rem 2.5rem;
    background-color: #05091a;
    border-top: 1px solid rgba(255,255,255,0.08);
    position: relative;
    overflow: hidden;
  }

  .hero__visual::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 60% 20%, rgba(59,130,246,0.1) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 20% 85%, rgba(34,211,238,0.07) 0%, transparent 60%);
    pointer-events: none;
  }

  /* ── Cards base ── */
  .panel-card {
    border-radius: var(--radius-lg);
    position: relative;
    z-index: 1;
    transition: border-color var(--transition-normal), transform var(--transition-normal);
  }
  .panel-card:hover {
    border-color: rgba(59,130,246,0.25);
    transform: translateY(-2px);
  }

  /* ── Mapa ── */
  .panel-map {
    height: 300px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    overflow: hidden;
  }

  .panel-card__head { display: flex; align-items: center; }

  .panel-eyebrow {
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-subtle);
  }

  .map__svg {
    width: 100%;
    flex: 1;
    min-height: 0;
    display: block;
  }

  .map__arc {
    fill: none;
    stroke-dashoffset: 600;
    animation: drawArc 2s cubic-bezier(0.4,0,0.2,1) forwards;
  }
  .map__arc--1 { animation-delay: 0.3s; }
  .map__arc--2 { animation-delay: 0.6s; }
  .map__arc--3 { animation-delay: 0.1s; }

  .map__ring { animation: mapPulse 2.8s ease-in-out infinite; }
  .map__ring--yellow { animation-delay: 0.5s; }
  .map__ring--blue   { animation-delay: 1s; }

  .map__city {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    fill: var(--color-text);
    letter-spacing: 0.01em;
  }
  .map__country {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 400;
    fill: var(--color-text-subtle);
    letter-spacing: 0.04em;
  }

  /* ── Terminal ── */
  .panel-terminal {
    height: 200px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
    background: rgba(2,6,23,0.85);
  }

  .terminal__bar {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1rem;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .terminal__dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .terminal__dot--red    { background: #ff5f57; }
  .terminal__dot--yellow { background: #febc2e; }
  .terminal__dot--green  { background: #28c840; }
  .terminal__title {
    font-family: var(--font-body);
    font-size: 0.5625rem;
    font-weight: 500;
    color: var(--color-text-subtle);
    letter-spacing: 0.06em;
    margin: 0 auto;
  }

  .terminal__body {
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    flex: 1;
    overflow: hidden;
  }

  .terminal__line {
    font-family: 'Courier New', 'Fira Code', monospace;
    font-size: 0.75rem;
    line-height: 1.6;
    opacity: 0;
    transform: translateY(3px);
    animation: fadeInLine 0.2s ease forwards;
    white-space: pre;
  }
  .t-l1 { animation-delay: 0.5s; }
  .t-l2 { animation-delay: 1.1s; }
  .t-l3 { animation-delay: 1.5s; }
  .t-l4 { animation-delay: 1.85s; }
  .t-l5 { animation-delay: 2.4s; }
  .t-l6 { animation-delay: 3.0s; }
  .t-l7 { animation-delay: 3.6s; }

  .t-prompt { color: #818cf8; }
  .t-cmd    { color: var(--color-text-muted); }
  .t-ok     { color: #22c55e; }
  .t-out    { color: #64748b; }
  .t-score  { color: #22d3ee; font-weight: 700; }
  .t-hi     { color: #a5f3fc; }
  .t-cursor {
    color: #22d3ee;
    opacity: 0;
    animation: blink 1s step-end infinite;
    animation-delay: 4s;
  }

  /* ======= TABLET (640px – 1023px) ======= */
  @media (min-width: 640px) and (max-width: 1023px) {
    .hero__content { padding: 5.5rem 3rem 3.5rem; gap: 2.5rem; }
    .hero__main { max-width: 560px; }
    .hero__description { max-width: 52ch; }
    .hero__visual { display: flex; padding: 2.5rem 3rem 3rem; }
    .panel-map { height: 360px; }
    .panel-terminal { height: 220px; }
  }

  /* ======= DESKTOP (≥1024px) ======= */
  @media (min-width: 1024px) {
    .hero { flex-direction: row; }

    .hero__content {
      width: 50%;
      padding: 5rem 4.5rem;
      gap: 0;
      justify-content: space-between;
    }
    .hero__main { max-width: 520px; }

    .hero__visual {
      width: 50%;
      padding: 3rem 2.5rem;
      border-top: none;
      border-left: 1px solid rgba(255,255,255,0.08);
    }

    .panel-map { height: auto; flex: 1; min-height: 0; padding: 1.5rem 1.75rem; }
    .panel-terminal { height: 190px; }
  }

  /* ======= KEYFRAMES ======= */
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(1.35); }
  }
  @keyframes mapPulse {
    0%, 100% { opacity: 0.55; }
    50%       { opacity: 0.12; }
  }
  @keyframes drawArc {
    to { stroke-dashoffset: 0; }
  }
  @keyframes fadeInLine {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>
