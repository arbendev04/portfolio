---
const stats = [
  { value: "5+",  label: "Proyectos lanzados" },
  { value: "2+",  label: "Años de experiencia" },
  { value: "10+", label: "Clientes en CO & ES" },
];
---

<section class="hero" id="inicio">
  <div class="hero__content">
    <!-- Header / logo -->
    <header class="hero__header animate-in">
      <div class="hero__logo" aria-hidden="true">
        <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path clip-rule="evenodd" d="M12.0799 24L4 19.2479L9.95537 8.75216L18.04 13.4961L18.0446 4H29.9554L29.96 13.4961L38.0446 8.75216L44 19.2479L35.92 24L44 28.7521L38.0446 39.2479L29.96 34.5039L29.9554 44H18.0446L18.04 34.5039L9.95537 39.2479L4 28.7521L12.0799 24Z" fill="currentColor" fill-rule="evenodd"/>
        </svg>
      </div>
      <span class="hero__brand">Santiago Arango · Dev</span>
    </header>

    <!-- Main copy -->
    <div class="hero__main">
      <span class="hero__tagline animate-in animate-in--delay-1">WordPress · Shopify · Código a Medida</span>
      <h1 class="hero__title animate-in animate-in--delay-2">
        Tu web que <em class="hero__title-em">vende</em>
        <span class="hero__title-sub">hecha para ganar.</span>
      </h1>
      <p class="hero__description animate-in animate-in--delay-3">
        Diseño y construyo webs que convierten visitas en clientes reales —
        sin plantillas genéricas. WordPress, Shopify o código a medida
        según lo que tu negocio realmente necesite.
      </p>
      <div class="hero__buttons animate-in animate-in--delay-4">
        <a href="#proyectos" class="btn btn--primary">Ver proyectos</a>
        <a href="#contacto" class="btn btn--outline">Pedir presupuesto →</a>
      </div>
    </div>

    <!-- Stats -->
    <div class="hero__stats animate-in animate-in--delay-5">
      {stats.map((stat) => (
        <div class="stat">
          <span class="stat__value">{stat.value}</span>
          <span class="stat__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Panel visual (desktop) -->
  <div class="hero__visual" aria-hidden="true">
    <div class="hero__bento">

      <!-- Trabajo reciente -->
      <div class="bento-card bento-card--project glass">
        <div class="bento-card__eyebrow">
          <span class="bento-label">Trabajo reciente</span>
          <span class="bento-live">
            <span class="bento-live__dot"></span>Live
          </span>
        </div>
        <p class="bento-card__project">Miami Colombian Swim</p>
        <div class="bento-tags">
          <span class="bento-tag">Shopify</span>
          <span class="bento-tag">E-Commerce</span>
        </div>
        <div class="bento-card__sep"></div>
        <p class="bento-card__project bento-card__project--sm">Arango Dental Clinic</p>
        <div class="bento-tags">
          <span class="bento-tag">WordPress</span>
          <span class="bento-tag">SEO Local</span>
        </div>
      </div>

      <!-- Stat -->
      <div class="bento-card bento-card--stat glass">
        <span class="bento-stat__value">10+</span>
        <span class="bento-stat__label">Clientes en CO & ES</span>
      </div>

      <!-- Disponibilidad -->
      <div class="bento-card bento-card--status glass">
        <span class="bento-status__dot"></span>
        <span class="bento-status__text">Disponible</span>
        <span class="bento-status__sub">Responde en &lt;24h</span>
      </div>

      <!-- Stack -->
      <div class="bento-card bento-card--stack glass">
        <span class="bento-label">Stack</span>
        <div class="bento-chips">
          <span class="bento-chip">WordPress</span>
          <span class="bento-chip">Shopify</span>
          <span class="bento-chip bento-chip--accent">Python</span>
          <span class="bento-chip">Django</span>
          <span class="bento-chip bento-chip--accent">PostgreSQL</span>
          <span class="bento-chip">REST APIs</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* ======= BASE ======= */
  .hero {
    display: flex;
    min-height: 100svh;
    background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 36px 36px;
  }

  /* ======= CONTENT ======= */
  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    padding: 1.75rem 1.25rem 2rem;
    gap: 3rem;
  }

  /* ======= HEADER ======= */
  .hero__header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .hero__logo {
    width: 1.75rem;
    height: 1.75rem;
    color: var(--color-primary);
    transition: transform var(--transition-slow);
    flex-shrink: 0;
  }

  .hero__header:hover .hero__logo { transform: rotate(90deg); }

  .hero__brand {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
  }

  /* ======= MAIN COPY ======= */
  .hero__main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero__tagline {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-primary);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9.5vw, 6.5rem);
    font-weight: 400; /* Bebas Neue solo tiene weight 400 */
    line-height: 0.95; /* condensed — puede ir más apretado */
    letter-spacing: 0.03em;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
  }

  /* "vende" — cancelamos la itálica que el browser aplica al <em> */
  .hero__title-em {
    font-style: normal;
    color: var(--color-primary);
  }

  /* Remate — misma tipografía que el tagline para unificar el bloque */
  .hero__title-sub {
    display: block;
    font-family: var(--font-display);
    font-size: 0.22em;
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-top: 1.2em;
    padding-left: 0.75em;
    border-left: 2px solid rgba(59, 130, 246, 0.5);
  }

  .hero__description {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.125rem);
    font-weight: 400;
    line-height: 1.75;
    color: var(--color-text-muted);
    max-width: 44ch;
  }

  /* ======= BOTONES ======= */
  .hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    font-family: var(--font-body); /* Montserrat — para que el peso sea visible */
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    cursor: pointer;
    min-height: 44px;
  }

  .btn--primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 16px rgba(59, 130, 246, 0.35);
  }

  .btn--primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.45);
  }

  .btn--outline {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .btn--outline:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
    transform: translateY(-2px);
    background: rgba(255,255,255,0.03);
  }

  /* ======= STATS ======= */
  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat__value {
    font-family: var(--font-body); /* Montserrat — tiene weights reales */
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }

  .stat__label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
  }

  /* ======= VISUAL (oculto en móvil) ======= */
  .hero__visual { display: none; }

  /* ======= TABLET (640px – 1023px) ======= */
  @media (min-width: 640px) and (max-width: 1023px) {
    .hero {
      flex-direction: column;
    }

    .hero__content {
      padding: 5.5rem 3rem 3.5rem;
      gap: 2.5rem;
    }

    .hero__main { max-width: 560px; }
    .hero__description { max-width: 52ch; }
  }

  /* ======= DESKTOP (≥1024px) ======= */
  @media (min-width: 1024px) {
    .hero {
      flex-direction: row;
    }

    .hero__content {
      width: 50%;
      padding: 5rem 4.5rem;
      gap: 0;
      justify-content: space-between;
    }

    .hero__main { max-width: 520px; }

    .hero__visual {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 50%;
      background-color: #05091a;
      border-left: 1px solid rgba(255,255,255,0.04);
      position: relative;
      overflow: hidden;
    }

    .hero__visual::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 70% 30%, rgba(59,130,246,0.08) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 30% 80%, rgba(34,211,238,0.05) 0%, transparent 60%);
      pointer-events: none;
    }

    /* ======= BENTO GRID ======= */
    .hero__bento {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.625rem;
      width: 100%;
      max-width: 400px;
      padding: 2.5rem 2rem;
      position: relative;
      z-index: 1;
    }

    .bento-card {
      border-radius: var(--radius-lg);
      padding: 1.125rem 1.25rem;
      transition: border-color var(--transition-normal), transform var(--transition-normal);
    }

    .bento-card:hover {
      border-color: rgba(59,130,246,0.22);
      transform: translateY(-2px);
    }

    /* Proyecto — ancho completo */
    .bento-card--project {
      grid-column: 1 / -1;
    }

    .bento-card__eyebrow {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.875rem;
    }

    .bento-label {
      font-family: var(--font-body);
      font-size: 0.625rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--color-text-subtle);
    }

    .bento-live {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      font-family: var(--font-body);
      font-size: 0.625rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #4ade80;
    }

    .bento-live__dot {
      width: 5px; height: 5px;
      background: #22c55e;
      border-radius: 50%;
      box-shadow: 0 0 6px #22c55e;
      animation: pulse 2s infinite;
    }

    .bento-card__project {
      font-family: var(--font-body);
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--color-text);
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
    }

    .bento-card__project--sm {
      font-size: 0.875rem;
      margin-top: 0.75rem;
      margin-bottom: 0.5rem;
    }

    .bento-tags {
      display: flex;
      gap: 0.375rem;
      flex-wrap: wrap;
    }

    .bento-tag {
      font-family: var(--font-body);
      font-size: 0.5625rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-primary);
      border: 1px solid rgba(59,130,246,0.25);
      padding: 0.2rem 0.5rem;
      border-radius: var(--radius-sm);
    }

    .bento-card__sep {
      height: 1px;
      background: var(--color-border);
      margin: 0.875rem 0 0;
    }

    /* Stat card */
    .bento-card--stat {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .bento-stat__value {
      font-family: var(--font-body);
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--color-primary);
      line-height: 1;
      letter-spacing: -0.04em;
    }

    .bento-stat__label {
      font-family: var(--font-body);
      font-size: 0.625rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-text-subtle);
      line-height: 1.4;
    }

    /* Status card */
    .bento-card--status {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .bento-status__dot {
      display: block;
      width: 7px; height: 7px;
      background: #22c55e;
      border-radius: 50%;
      box-shadow: 0 0 8px #22c55e;
      margin-bottom: 0.375rem;
      animation: pulse 2s infinite;
    }

    .bento-status__text {
      font-family: var(--font-body);
      font-size: 0.875rem;
      font-weight: 600;
      color: #4ade80;
      letter-spacing: -0.01em;
    }

    .bento-status__sub {
      font-family: var(--font-body);
      font-size: 0.625rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-text-subtle);
    }

    /* Stack card — ancho completo */
    .bento-card--stack {
      grid-column: 1 / -1;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .bento-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
    }

    .bento-chip {
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      padding: 0.3rem 0.7rem;
      border-radius: var(--radius-full);
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      color: var(--color-text-muted);
      letter-spacing: 0.02em;
      transition: all var(--transition-fast);
    }

    .bento-chip:hover {
      background: rgba(59,130,246,0.08);
      border-color: rgba(59,130,246,0.2);
      color: var(--color-text);
    }

    .bento-chip--accent {
      background: rgba(34,211,238,0.06);
      border-color: rgba(34,211,238,0.15);
      color: var(--color-accent);
    }

    .bento-chip--accent:hover {
      background: rgba(34,211,238,0.12);
      border-color: rgba(34,211,238,0.3);
    }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(1.3); }
  }
</style>
