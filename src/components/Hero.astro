---
const stats = [
  { value: "5+",  label: "Proyectos en producción" },
  { value: "2+",  label: "Años de experiencia" },
  { value: "10+", label: "Clientes satisfechos" },
];
---

<section class="hero" id="inicio">
  <div class="hero__content">
    <!-- Header / logo -->
    <header class="hero__header animate-in">
      <div class="hero__logo" aria-hidden="true">
        <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
          <path clip-rule="evenodd" d="M12.0799 24L4 19.2479L9.95537 8.75216L18.04 13.4961L18.0446 4H29.9554L29.96 13.4961L38.0446 8.75216L44 19.2479L35.92 24L44 28.7521L38.0446 39.2479L29.96 34.5039L29.9554 44H18.0446L18.04 34.5039L9.95537 39.2479L4 28.7521L12.0799 24Z" fill="currentColor" fill-rule="evenodd"/>
        </svg>
      </div>
      <span class="hero__brand">Santiago Arango Benjumea · Dev</span>
    </header>

    <!-- Main copy -->
    <div class="hero__main">
      <span class="hero__tagline animate-in animate-in--delay-1">WordPress · WooCommerce · Desarrollo a Medida</span>
      <h1 class="hero__title animate-in animate-in--delay-2">
        Tu web que <em class="hero__title-em">vende</em>
        <span class="hero__title-sub">tú a lo tuyo.</span>
      </h1>
      <p class="hero__description animate-in animate-in--delay-3">
        Creo sitios web y tiendas en línea que trabajan por ti — más visitas,
        más contactos, más ventas. WordPress, código propio o lo que tu negocio necesite.
      </p>
      <div class="hero__buttons animate-in animate-in--delay-4">
        <a href="#proyectos" class="btn btn--primary">Ver proyectos</a>
        <a href="#contacto" class="btn btn--outline">Hablemos →</a>
      </div>
    </div>

    <!-- Stats -->
    <div class="hero__stats animate-in animate-in--delay-5">
      {stats.map((stat) => (
        <div class="stat">
          <span class="stat__value">{stat.value}</span>
          <span class="stat__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Panel visual (desktop) -->
  <div class="hero__visual" aria-hidden="true">
    <div class="hero__orbit-system">
      <div class="hero__orbit hero__orbit--outer">
        <div class="hero__orbit-dot hero__orbit-dot--primary"></div>
      </div>
      <div class="hero__orbit hero__orbit--mid">
        <div class="hero__orbit-dot hero__orbit-dot--accent"></div>
      </div>
      <div class="hero__center">
        <span class="hero__center-initials">SA</span>
        <span class="hero__center-status">
          <span class="hero__center-dot"></span>
          Online
        </span>
      </div>
      <div class="hero__float hero__float--1">WordPress</div>
      <div class="hero__float hero__float--2">E-Commerce</div>
      <div class="hero__float hero__float--3">Python</div>
    </div>
  </div>
</section>

<style>
  /* ======= BASE ======= */
  .hero {
    display: flex;
    min-height: 100svh;
    background-image: radial-gradient(circle, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 36px 36px;
  }

  /* ======= CONTENT ======= */
  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    padding: 1.75rem 1.25rem 2rem;
    gap: 3rem;
  }

  /* ======= HEADER ======= */
  .hero__header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .hero__logo {
    width: 1.75rem;
    height: 1.75rem;
    color: var(--color-primary);
    transition: transform var(--transition-slow);
    flex-shrink: 0;
  }

  .hero__header:hover .hero__logo { transform: rotate(90deg); }

  .hero__brand {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-text-muted);
  }

  /* ======= MAIN COPY ======= */
  .hero__main {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero__tagline {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-primary);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9.5vw, 6.5rem);
    font-weight: 400; /* Bebas Neue solo tiene weight 400 */
    line-height: 0.95; /* condensed — puede ir más apretado */
    letter-spacing: 0.03em;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
  }

  /* "vende" — cancelamos la itálica que el browser aplica al <em> */
  .hero__title-em {
    font-style: normal;
    color: var(--color-primary);
  }

  /* Remate — misma tipografía que el tagline para unificar el bloque */
  .hero__title-sub {
    display: block;
    font-family: var(--font-display);
    font-size: 0.22em;
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-top: 1.2em;
    padding-left: 0.75em;
    border-left: 2px solid rgba(59, 130, 246, 0.5);
  }

  .hero__description {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.125rem);
    font-weight: 400;
    line-height: 1.75;
    color: var(--color-text-muted);
    max-width: 44ch;
  }

  /* ======= BOTONES ======= */
  .hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    font-family: var(--font-body); /* Montserrat — para que el peso sea visible */
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    cursor: pointer;
    min-height: 44px;
  }

  .btn--primary {
    background: var(--color-primary);
    color: white;
    box-shadow: 0 4px 16px rgba(59, 130, 246, 0.35);
  }

  .btn--primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.45);
  }

  .btn--outline {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .btn--outline:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text);
    transform: translateY(-2px);
    background: rgba(255,255,255,0.03);
  }

  /* ======= STATS ======= */
  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-border);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .stat__value {
    font-family: var(--font-body); /* Montserrat — tiene weights reales */
    font-size: 1.625rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }

  .stat__label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
  }

  /* ======= VISUAL (oculto en móvil) ======= */
  .hero__visual { display: none; }

  /* ======= TABLET (640px – 1023px) ======= */
  @media (min-width: 640px) and (max-width: 1023px) {
    .hero {
      flex-direction: column;
    }

    .hero__content {
      padding: 5.5rem 3rem 3.5rem;
      gap: 2.5rem;
    }

    .hero__main { max-width: 560px; }
    .hero__description { max-width: 52ch; }
  }

  /* ======= DESKTOP (≥1024px) ======= */
  @media (min-width: 1024px) {
    .hero {
      flex-direction: row;
    }

    .hero__content {
      width: 50%;
      padding: 5rem 4.5rem;
      gap: 0;
      justify-content: space-between;
    }

    .hero__main { max-width: 520px; }

    .hero__visual {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 50%;
      background-color: #05091a;
      border-left: 1px solid rgba(255,255,255,0.04);
      position: relative;
      overflow: hidden;
    }

    .hero__visual::before {
      content: "";
      position: absolute;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(59,130,246,0.07) 0%, transparent 65%);
      pointer-events: none;
    }

    .hero__orbit-system {
      position: relative;
      width: 420px;
      height: 420px;
    }

    .hero__orbit {
      position: absolute;
      border-radius: 50%;
      border: 1px dashed rgba(59,130,246,0.18);
    }

    .hero__orbit--outer {
      inset: 0;
      animation: spin 16s linear infinite;
    }

    .hero__orbit--mid {
      inset: 80px;
      border-color: rgba(34,211,238,0.13);
      animation: spin 10s linear infinite reverse;
    }

    .hero__orbit-dot {
      position: absolute;
      border-radius: 50%;
    }

    .hero__orbit-dot--primary {
      width: 10px; height: 10px;
      background: var(--color-primary);
      box-shadow: 0 0 16px var(--color-primary), 0 0 32px rgba(59,130,246,0.4);
      top: -5px; left: 50%;
      transform: translateX(-50%);
    }

    .hero__orbit-dot--accent {
      width: 7px; height: 7px;
      background: var(--color-accent);
      box-shadow: 0 0 12px var(--color-accent);
      bottom: -4px; left: 50%;
      transform: translateX(-50%);
    }

    .hero__center {
      position: absolute;
      inset: 135px;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(59,130,246,0.1), rgba(34,211,238,0.04));
      border: 1px solid rgba(59,130,246,0.25);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .hero__center-initials {
      font-family: var(--font-heading);
      font-size: 2.25rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.03em;
    }

    .hero__center-status {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      font-family: var(--font-heading);
      font-size: 0.625rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--color-text-muted);
    }

    .hero__center-dot {
      width: 5px; height: 5px;
      background: #22c55e;
      border-radius: 50%;
      box-shadow: 0 0 8px #22c55e;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50%       { opacity: 0.5; transform: scale(1.3); }
    }

    .hero__float {
      position: absolute;
      font-family: var(--font-heading);
      font-size: 0.625rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--color-text-muted);
      background: rgba(9,15,35,0.92);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 0.375rem 0.875rem;
      border-radius: var(--radius-full);
      backdrop-filter: blur(8px);
      white-space: nowrap;
    }

    .hero__float--1 { top: 12%; right: -10px; animation: floatTag 5s ease-in-out infinite; }
    .hero__float--2 { bottom: 22%; left: -20px; animation: floatTag 5s ease-in-out infinite 1.7s; }
    .hero__float--3 { top: 52%; right: -15px; animation: floatTag 5s ease-in-out infinite 3.2s; }
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  @keyframes floatTag {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-8px); }
  }
</style>
