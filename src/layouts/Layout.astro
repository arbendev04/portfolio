---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Desarrollador web freelance especializado en WordPress, WooCommerce y soluciones a medida. Convierto visitas en clientes reales. Disponible para proyectos en 2026.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://santiago-arango.dev");

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Santiago Arango",
  url: canonicalURL.origin,
  jobTitle: "Desarrollador Web Freelance",
  description: "Desarrollador web especializado en WordPress, WooCommerce, Python y soluciones a medida.",
  knowsAbout: ["WordPress", "WooCommerce", "PHP", "Python", "Django", "PostgreSQL", "E-Commerce", "REST APIs"],
  sameAs: [
    "https://github.com/ArbenS90",
    "https://www.linkedin.com/in/santiago-arango-benjumea-383864219/",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    email: "arben04dev@gmail.com",
    contactType: "customer support",
  },
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Santiago Arango" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="Santiago Arango · Dev" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fuentes: preconnect + carga optimizada (solo pesos usados) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:ital,wght@0,300..700;1,300..700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
