---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Desarrollador web freelance en Colombia. WordPress, Shopify y código a medida para negocios que quieren crecer. Presupuesto en menos de 24 horas.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://arben.dev");
const ogImage = new URL("/og-image.webp", Astro.site ?? "https://arben.dev");

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Santiago Arango",
  url: canonicalURL.origin,
  jobTitle: "Desarrollador Web Freelance",
  description: "Desarrollador web freelance en Colombia especializado en WordPress, Shopify y soluciones a medida que convierten visitas en clientes.",
  knowsAbout: ["WordPress", "WooCommerce", "Shopify", "PHP", "Python", "Django", "PostgreSQL", "E-Commerce", "REST APIs", "Diseño Web"],
  sameAs: [
    "https://github.com/ArbenS90",
    "https://www.linkedin.com/in/santiago-arango-benjumea-383864219/",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    email: "arben04dev@gmail.com",
    contactType: "customer service",
    availableLanguage: ["Spanish"],
    areaServed: ["CO", "ES", "LATAM"],
  },
  worksFor: {
    "@type": "Organization",
    name: "SYS-ENG",
    url: canonicalURL.origin,
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Santiago Arango · Dev",
  url: canonicalURL.origin,
  description: "Portafolio de Santiago Arango, desarrollador web freelance en Colombia.",
  author: {
    "@type": "Person",
    name: "Santiago Arango",
  },
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Santiago Arango" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="Santiago Arango · Dev" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons multi-dispositivo -->
    <link rel="icon" href="/favicos/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicos/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicos/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicos/apple-touch-icon.png" />
    <link rel="manifest" href="/favicos/site.webmanifest" />
    <meta name="theme-color" content="#111827" />

    <!-- Fuentes: preconnect + carga optimizada (solo pesos usados) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:ital,wght@0,300..700;1,300..700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
